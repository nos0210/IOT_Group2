{
    "write_flash_args" : [ "--flash-mode", "dio",
                           "--flash-size", "4MB",
                           "--flash-freq", "40m" ],
    "flash_settings" : {
        "flash_mode": "dio",
        "flash_size": "4MB",
        "flash_freq": "40m"
    },
    "flash_files" : {
        "0xd000" : "partition_table/partition-table.bin",
        "0x13000" : "ota_data_initial.bin",
        "0x20000" : "$<TARGET_PROPERTY:__idf_build_target,EXECUTABLE_NAME>.bin"
    },
    "partition-table" : { "offset" : "0xd000", "file" : "partition_table/partition-table.bin", "encrypted" : "false" },
    "otadata" : { "offset" : "0x13000", "file" : "ota_data_initial.bin", "encrypted" : "false" },
    "app" : { "offset" : "0x20000", "file" : "$<TARGET_PROPERTY:__idf_build_target,EXECUTABLE_NAME>.bin", "encrypted" : "false" },
    "extra_esptool_args" : {
        "after"  : "no-reset",
        "before" : "default-reset",
        "stub"   : true,
        "chip"   : "esp32"
    }
}
